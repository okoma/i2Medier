APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ADMIN_DOMAIN=
CLIENT_DOMAIN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── DEFAULT MAILER ────────────────────────────────────────────────────────────
# Set to "transactional", "newsletter", "log", or "array"
MAIL_MAILER=log

# ── TRANSACTIONAL EMAILS ──────────────────────────────────────────────────────
# Used for: password resets, contact forms, order confirmations, notifications
# Set MAIL_TRANSACTIONAL_TRANSPORT=smtp  → fill the SMTP block below
# Set MAIL_TRANSACTIONAL_TRANSPORT=ses   → fill the AWS / SES block below
MAIL_TRANSACTIONAL_TRANSPORT=smtp
MAIL_TRANSACTIONAL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_TRANSACTIONAL_FROM_NAME="${APP_NAME}"

# SMTP (transactional)
MAIL_TRANSACTIONAL_SCHEME=tls
MAIL_TRANSACTIONAL_HOST=smtp.mailgun.org
MAIL_TRANSACTIONAL_PORT=587
MAIL_TRANSACTIONAL_USERNAME=
MAIL_TRANSACTIONAL_PASSWORD=

# ── NEWSLETTER / MARKETING EMAILS ─────────────────────────────────────────────
# Used for: campaigns, announcements, bulk sends
# Set MAIL_NEWSLETTER_TRANSPORT=smtp  → fill the SMTP block below
# Set MAIL_NEWSLETTER_TRANSPORT=ses   → fill the AWS / SES block below
MAIL_NEWSLETTER_TRANSPORT=smtp
MAIL_NEWSLETTER_FROM_ADDRESS="news@yourdomain.com"
MAIL_NEWSLETTER_FROM_NAME="${APP_NAME}"

# SMTP (newsletter) — can share the same host or use a separate sending domain
MAIL_NEWSLETTER_SCHEME=tls
MAIL_NEWSLETTER_HOST=smtp.mailgun.org
MAIL_NEWSLETTER_PORT=587
MAIL_NEWSLETTER_USERNAME=
MAIL_NEWSLETTER_PASSWORD=

# ── AWS SES ───────────────────────────────────────────────────────────────────
# Used when either transport above is set to "ses" or "ses-v2"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_SES_REGION=us-east-1

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── LEGACY / FALLBACK ─────────────────────────────────────────────────────────
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

BANK_TRANSFER_ACCOUNT_NAME="i2Medier"
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_SORT_CODE=
BANK_TRANSFER_INSTRUCTIONS="Use the invoice number as your transfer reference and send proof of payment after transfer."

VITE_APP_NAME="${APP_NAME}"
